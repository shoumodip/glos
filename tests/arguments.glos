use std.libc

fn main() {
    # TODO: implement the `for init, cond, update` form
    let i = 0
    for i < argc {
        syscall(1, 1, argv[i], cstr_size(argv[i]))
        syscall(1, 1, "\n"c, 1)

        # TODO: implement the '+=' operator
        i = i + 1
    }
}
