fn main() {
    const N = 3
    let xs [N][N]int

    let i = 0
    for i < N {
        let j = 0
        for j < N {
            xs[i][j] = (i + 1) * (j + 1)
            j = j + 1
        }
        i = i + 1
    }

    i = 0
    for i < N {
        let j = 0
        for j < N {
            print xs[i][j]
            j = j + 1
        }
        i = i + 1
    }
}
